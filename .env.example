# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# GitHub token used by the update scripts to authenticate GitHub API calls
# (raises the rate limit from 60/hour to 5000/hour and avoids 403).
# A fine-grained token with public read access is enough.
GITHUB_TOKEN=

# Optional download proxy for the update scripts. Point this at a proxy shared by
# another device on your LAN (host + port) so downloads go through a connection
# that can reach GitHub. Supports http(s) and socks5h, for example:
#   DOWNLOAD_PROXY=http://192.168.2.7:7897
#   DOWNLOAD_PROXY=socks5h://192.168.2.7:7897
# When set, downloads try the proxy first and fall back to a direct connection.
DOWNLOAD_PROXY=
