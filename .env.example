# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# GitHub token used by the update scripts to authenticate GitHub API calls
# (raises the rate limit from 60/hour to 5000/hour and avoids 403).
# A fine-grained token with public read access is enough.
GITHUB_TOKEN=

# Optional download proxy for the update scripts. Point this at a proxy shared by
# another device on your LAN (host + port) so downloads go through a connection
# that can reach GitHub. Supports http(s) and socks5h, for example:
#   DOWNLOAD_PROXY=http://192.168.2.7:7897
#   DOWNLOAD_PROXY=socks5h://192.168.2.7:7897
# When set, downloads try the proxy first and fall back to a direct connection.
DOWNLOAD_PROXY=

# Expose this machine to your LAN, read by the service setup scripts. Accepts
# true/false (also 1/yes/on for true). Default when unset: false (local only).
#   - Mihomo (setup_mihomo_service.sh): toggles allow-lan so other LAN devices
#     can use this machine as a proxy. The Web dashboard stays bound to 127.0.0.1.
#   - sing-box (setup_sing_box_service.sh): toggles whether the Clash API / Web UI
#     panel listens on 0.0.0.0:9090 (LAN) instead of 127.0.0.1:9090. The proxy
#     inbound stays on loopback either way.
ALLOW_LAN=false
